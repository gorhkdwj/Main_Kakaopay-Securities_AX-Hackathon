# 판단 여권 · 환경변수 템플릿 (S5 LLM 브리핑 — D-0717-2323-main)
#
# 사용법: 이 파일을 `.env`로 복사한 뒤 값을 채운다. `.env`는 Git 제외이며
# 키를 채팅·문서·커밋에 절대 넣지 않는다(헌법 §7 — 로그 편집 = 실격 사유).
#     copy .env.example .env        (PowerShell/cmd)

# [필수 — 라이브 브리핑용] Anthropic API 키 (console.anthropic.com에서 발급, sk-ant-... 형태)
# 비워 두면 네트워크를 시도하지 않고 캐시→정적 조립으로 완주한다(오프라인 데모 경로).
ANTHROPIC_API_KEY=

# [선택] 브리핑 생성 모델 (기본값: claude-sonnet-5)
# ANTHROPIC_MODEL=claude-sonnet-5

# [선택] 브리핑 원천 모드 (기본값: auto = 키 있으면 live 시도, 실패 시 cache→static)
# 시연 중 라이브 지연이 거슬리면 cache로 고정한다.
# BRIEFING_MODE=auto
